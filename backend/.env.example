# ──────────────────────────────────────────
#  PantryMatch — Backend Environment Variables
#  Copy this file to .env and fill in values
# ──────────────────────────────────────────

# MongoDB connection string
# Local:   mongodb://127.0.0.1:27017/pantry
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/pantry
MONGO_URI=mongodb://127.0.0.1:27017/pantry

# JWT secret — any long random string (keep it secret!)
JWT_SECRET=your_super_secret_key_here

# Port the backend server runs on
PORT=5055
